# Local development defaults — copy to .env and edit as needed
ACADEMY_JWT_SECRET=change_me_in_production
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
VITE_API_URL=http://localhost:8000

# Coolify production environment variables (set in Coolify UI, not this file)
# SERVICE_FQDN_BACKEND_8000=api.your-domain.com   ← note the _8000 suffix
# SERVICE_FQDN_FRONTEND=your-domain.com
# ACADEMY_JWT_SECRET=<strong random secret>
# FRONTEND_ORIGINS=https://your-domain.com
# VITE_API_URL=https://api.your-domain.com
